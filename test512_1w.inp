&simulation
   nsteps=100
   stamp=100
   stamp2D=1000
   stamp_term=100
   stepskip=1
   lreadisfluid=.false.   !metti true se leggi isfluid
   lreadinit=.false.  !metti true se leggi rho phi e u v w
   lwriterestart=.false.
   lx=512
   ly=512
   lz=512
   iprobe=96
   jprobe=64
   kprobe=64
   lprint=.true.
   lvtk=.false.
   lraw=.false.
   lasync=.false.
   lrestart=.false. !metti true se riparti da restart
   lweakscaling=.true.
   pbc_x=1  !(0=false 1=true)
   pbc_y=1
   pbc_z=1
   !openbc=0
   nplanes=0
&end
&fluid
   !uwall=-0.0e0
   fx=1.0e-6
   fy=0.0e-6
   fz=0.0e-6
   !tau_diff=0.12e0
   radius=16.0e0
   width=8.0e0
   center=112.0e0,64.0e0,64.0e0
   !sigma=0.01e0
   !wettab_r=0.85e0
   !wettab_b=1.0e0
   visc1= 0.1e0 !0.025e0
   !tau1= 1.0
   !visc2= 0.025e0
   !rho_r=5.0e0
   !rho_b=0.5e0
   !npoint = 32!, 32, 32
   !ndir = 1!, 2, 3
&end

